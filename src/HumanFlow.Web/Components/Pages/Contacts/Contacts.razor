@page "/contacts"
@using HumanFlow.Domain.Contacts
@using HumanFlow.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<PageTitle>Contactos — HumanFlow</PageTitle>

<div class="hf-page-header">
    <div>
        <h1>Contactos</h1>
        <p class="hf-page-subtitle">Contactos internos y externos reutilizables por RRHH.</p>
    </div>
    <span class="hf-badge hf-badge-primary">@(_contacts?.Count ?? 0) contactos</span>
</div>

@if (_contacts is null)
{
    <div class="hf-loading">
        <div class="hf-loading-spinner"></div>
        Cargando contactos&hellip;
    </div>
}
else
{
    <div class="hf-table-wrapper">
        <table class="hf-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Clase</th>
                    <th>Tipo</th>
                    <th>Organización</th>
                    <th>Email</th>
                    <th>Teléfono</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contact in _contacts)
                {
                    <tr>
                        <td style="font-weight:600">@contact.DisplayName</td>
                        <td>
                            <span class="@KindClass(contact.Kind)">@contact.Kind</span>
                        </td>
                        <td style="color:var(--color-foreground-muted)">@contact.Type</td>
                        <td style="color:var(--color-foreground-muted)">@contact.OrganizationName</td>
                        <td style="color:var(--color-foreground-muted)">@contact.Email</td>
                        <td style="color:var(--color-foreground-muted)">@contact.Phone</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Contact>? _contacts;

    protected override async Task OnInitializedAsync()
    {
        _contacts = await DbContext.Contacts
            .OrderBy(x => x.Kind)
            .ThenBy(x => x.DisplayName)
            .ToListAsync();
    }

    private static string KindClass(ContactKind kind) =>
        kind switch
        {
            ContactKind.Internal => "hf-badge hf-badge-primary",
            ContactKind.External => "hf-badge hf-badge-neutral",
            _                   => "hf-badge hf-badge-neutral"
        };
}
