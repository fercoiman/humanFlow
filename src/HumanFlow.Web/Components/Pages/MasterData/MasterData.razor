    {
        _editLocalityId = l.Id;
        _editLocality   = new() { CityId = l.CityId.ToString(), Name = l.Name, PostalCode = l.PostalCode ?? "", IsActive = l.IsActive };
    }

    private async Task UpdateLocality(Guid id)
    {
        var entity = await DbContext.Localities.FindAsync(id);
        if (entity is null) return;
        if (Guid.TryParse(_editLocality.CityId, out var cityGuid))
            entity.CityId = cityGuid;
        entity.Name       = _editLocality.Name.Trim();
        entity.PostalCode = string.IsNullOrWhiteSpace(_editLocality.PostalCode) ? null : _editLocality.PostalCode.Trim();
        entity.IsActive   = _editLocality.IsActive;
        entity.UpdatedAt  = DateTimeOffset.UtcNow;
        await DbContext.SaveChangesAsync();
        _editLocalityId = null;
        await LoadLocalities();
