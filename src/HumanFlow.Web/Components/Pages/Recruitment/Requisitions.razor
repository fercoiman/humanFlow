@page "/recruitment"
@rendermode InteractiveServer
@using HumanFlow.Domain.Organization
@using HumanFlow.Web.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager Nav

<PageTitle>Reclutamiento — HumanFlow</PageTitle>

@if (_loading)
{
    <div class="hf-loading-state">
        <div class="hf-spinner"></div>
        <span>Cargando...</span>
    </div>
}
else
{
    <div class="hf-page-header">
        <div>
            <p class="hf-page-subtitle">HumanFlow</p>
            <h1 class="hf-page-title">Reclutamiento</h1>
        </div>
        @if (!_showForm)
        {
            <button class="btn btn-primary" @onclick="() => _showForm = true">+ Nueva requisición</button>
        }
    </div>

    <div class="hf-stats-grid">
        <div class="hf-stat-card">
            <p class="hf-stat-value">@_requisitions.Count</p>
            <p class="hf-stat-label">Total</p>
        </div>
        <div class="hf-stat-card">
            <p class="hf-stat-value hf-stat-success">@_requisitions.Count(r => r.Status == RequisitionStatus.Open)</p>
            <p class="hf-stat-label">Abiertas</p>
        </div>
        <div class="hf-stat-card">
            <p class="hf-stat-value hf-stat-primary">@_requisitions.Count(r => r.Status == RequisitionStatus.InProgress)</p>
            <p class="hf-stat-label">En proceso</p>
        </div>
        <div class="hf-stat-card">
            <p class="hf-stat-value hf-stat-muted">@_requisitions.Count(r => r.Status == RequisitionStatus.Filled || r.Status == RequisitionStatus.Cancelled)</p>
            <p class="hf-stat-label">Cerradas</p>
        </div>
    </div>

    @if (_showForm)
    {
        <div class="hf-section" style="margin-bottom:1.5rem">
            <div class="hf-add-form">
                <p class="hf-add-form-title">Nueva requisición</p>
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="hf-alert-error" style="margin-bottom:.75rem">@_formError</div>
                }
                <div class="hf-form-grid">
                    <div class="hf-form-grid-full">
                        <label class="hf-field-label form-label">Título del puesto <span style="color:var(--color-destructive)">*</span></label>
                        <input class="form-control form-control-sm" @bind="_nf.Title" placeholder="Ej: Analista de RRHH Senior" />
                    </div>
                    <div>
                        <label class="hf-field-label form-label">Puesto (catálogo)</label>
                        <select class="form-select form-select-sm" @bind="_nf.JobPositionId">
                            <option value="">— Sin asignar —</option>
                            @foreach (var p in _jobPositions)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="hf-field-label form-label">Área</label>
                        <select class="form-select form-select-sm" @bind="_nf.OrganizationUnitId">
                            <option value="">— Sin asignar —</option>
                            @foreach (var u in _orgUnits)
                            {
                                <option value="@u.Id">@u.Name</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="hf-field-label form-label">Prioridad</label>
                        <InputSelect TValue="RequisitionPriority" @bind-Value="_nf.Priority" class="form-select form-select-sm">
                            <option value="@RequisitionPriority.Low">Baja</option>
                            <option value="@RequisitionPriority.Normal">Normal</option>
                            <option value="@RequisitionPriority.High">Alta</option>
                            <option value="@RequisitionPriority.Urgent">Urgente</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="hf-field-label form-label">Vacantes</label>
                        <input class="form-control form-control-sm" type="number" min="1" @bind="_nf.VacanciesCount" />
                    </div>
                    <div>
                        <label class="hf-field-label form-label">Fecha de apertura</label>
                        <InputDate TValue="DateOnly?" @bind-Value="_nf.OpenDate" class="form-control form-control-sm" />
                    </div>
                    <div style="display:flex;align-items:center;gap:.5rem;padding-top:1.25rem">
                        <input class="form-check-input" type="checkbox" id="chkRemote" @bind="_nf.IsRemote" />
                        <label class="hf-field-label" for="chkRemote" style="margin:0">Posición remota</label>
                    </div>
                </div>
                <div class="hf-form-actions">
                    <button class="btn btn-primary btn-sm" @onclick="SaveNewRequisition">Crear requisición</button>
                    <button class="btn-hf-secondary" @onclick="() => { _showForm = false; _formError = null; _nf = new(); }">Cancelar</button>
                </div>
            </div>
        </div>
    }

    <div class="hf-section">
        @if (_requisitions.Count == 0)
        {
            <div class="hf-section-body" style="padding:3rem;text-align:center;color:var(--color-foreground-muted)">
                No hay requisiciones. Crea la primera con el botón de arriba.
            </div>
        }
        else
        {
            <div class="hf-table-wrapper">
                <table class="hf-table">
                    <thead>
                        <tr>
                            <th>N° / Puesto</th>
                            <th>Área</th>
                            <th>Prioridad</th>
                            <th style="text-align:center">Vacantes</th>
                            <th style="text-align:center">Candidatos</th>
                            <th>Apertura</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in _requisitions)
                        {
                            var count = _counts.GetValueOrDefault(req.Id, 0);
                            <tr>
                                <td>
                                    <div>
                                        <span class="hf-emp-number">@req.RequisitionNumber</span>
                                        <span style="font-weight:600;margin-left:.5rem">@req.Title</span>
                                    </div>
                                    @if (req.IsRemote)
                                    {
                                        <span class="hf-badge hf-badge-neutral" style="font-size:.7rem;margin-top:.25rem;display:inline-block">Remoto</span>
                                    }
                                </td>
                                <td style="color:var(--color-foreground-muted)">@GetUnitName(req.OrganizationUnitId)</td>
                                <td><span class="@PriorityClass(req.Priority)">@PriorityLabel(req.Priority)</span></td>
                                <td style="text-align:center;color:var(--color-foreground-muted)">@req.VacanciesCount</td>
                                <td style="text-align:center;color:var(--color-foreground-muted)">@count</td>
                                <td style="color:var(--color-foreground-muted)">@(req.OpenDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td><span class="@ReqStatusClass(req.Status)">@ReqStatusLabel(req.Status)</span></td>
                                <td style="text-align:right">
                                    <a class="btn-hf-secondary" href="/recruitment/@req.Id"
                                       style="padding:.25rem .75rem;font-size:.75rem;text-decoration:none;display:inline-block">Ver</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _showForm;
    private string? _formError;
    private List<JobRequisition> _requisitions = [];
    private Dictionary<Guid, int> _counts = [];
    private List<JobPosition> _jobPositions = [];
    private List<OrganizationUnit> _orgUnits = [];
    private NewReqForm _nf = new();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        _loading = true;
        var tid = await DbContext.Tenants.Select(t => t.Id).FirstOrDefaultAsync();

        _requisitions = await DbContext.JobRequisitions
            .Where(r => r.TenantId == tid && !r.IsDeleted)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();

        var reqIds = _requisitions.Select(r => r.Id).ToList();
        if (reqIds.Count > 0)
        {
            _counts = await DbContext.JobApplications
                .Where(a => reqIds.Contains(a.JobRequisitionId) && !a.IsDeleted)
                .GroupBy(a => a.JobRequisitionId)
                .Select(g => new { Id = g.Key, Count = g.Count() })
                .ToDictionaryAsync(x => x.Id, x => x.Count);
        }

        _jobPositions = await DbContext.JobPositions
            .Where(j => j.TenantId == tid && j.IsActive)
            .OrderBy(j => j.Title)
            .ToListAsync();

        _orgUnits = await DbContext.OrganizationUnits
            .Where(u => u.TenantId == tid)
            .OrderBy(u => u.Name)
            .ToListAsync();

        _loading = false;
    }

    private async Task SaveNewRequisition()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_nf.Title))
        {
            _formError = "El título del puesto es obligatorio.";
            return;
        }

        var tid = await DbContext.Tenants.Select(t => t.Id).FirstOrDefaultAsync();
        var existingCount = await DbContext.JobRequisitions.CountAsync(r => r.TenantId == tid);
        var reqNumber = $"REQ-{existingCount + 1:D3}";

        var req = new JobRequisition
        {
            TenantId = tid,
            RequisitionNumber = reqNumber,
            Title = _nf.Title.Trim(),
            JobPositionId = ToGuid(_nf.JobPositionId),
            OrganizationUnitId = ToGuid(_nf.OrganizationUnitId),
            Status = RequisitionStatus.Open,
            Priority = _nf.Priority,
            VacanciesCount = _nf.VacanciesCount,
            OpenDate = _nf.OpenDate,
            IsRemote = _nf.IsRemote
        };

        DbContext.JobRequisitions.Add(req);
        await DbContext.SaveChangesAsync();
        Nav.NavigateTo($"/recruitment/{req.Id}");
    }

    private string GetUnitName(Guid? id) =>
        id is null ? "—" : (_orgUnits.FirstOrDefault(u => u.Id == id)?.Name ?? "—");

    private static Guid? ToGuid(string? s) =>
        Guid.TryParse(s, out var g) ? g : null;

    private static string ReqStatusLabel(RequisitionStatus s) => s switch
    {
        RequisitionStatus.Draft      => "Borrador",
        RequisitionStatus.Open       => "Abierta",
        RequisitionStatus.InProgress => "En proceso",
        RequisitionStatus.OnHold     => "En pausa",
        RequisitionStatus.Filled     => "Cubierta",
        RequisitionStatus.Cancelled  => "Cancelada",
        _                            => s.ToString()
    };

    private static string ReqStatusClass(RequisitionStatus s) => s switch
    {
        RequisitionStatus.Open       => "hf-badge hf-badge-success",
        RequisitionStatus.InProgress => "hf-badge hf-badge-primary",
        RequisitionStatus.OnHold     => "hf-badge hf-badge-warning",
        RequisitionStatus.Filled     => "hf-badge hf-badge-purple",
        _                            => "hf-badge hf-badge-neutral"
    };

    private static string PriorityLabel(RequisitionPriority p) => p switch
    {
        RequisitionPriority.Low    => "Baja",
        RequisitionPriority.Normal => "Normal",
        RequisitionPriority.High   => "Alta",
        RequisitionPriority.Urgent => "Urgente",
        _                          => p.ToString()
    };

    private static string PriorityClass(RequisitionPriority p) => p switch
    {
        RequisitionPriority.Urgent => "hf-badge hf-badge-danger",
        RequisitionPriority.High   => "hf-badge hf-badge-warning",
        RequisitionPriority.Normal => "hf-badge hf-badge-primary",
        _                          => "hf-badge hf-badge-neutral"
    };

    private sealed class NewReqForm
    {
        public string Title { get; set; } = "";
        public string JobPositionId { get; set; } = "";
        public string OrganizationUnitId { get; set; } = "";
        public RequisitionPriority Priority { get; set; } = RequisitionPriority.Normal;
        public int VacanciesCount { get; set; } = 1;
        public DateOnly? OpenDate { get; set; }
        public bool IsRemote { get; set; }
    }
}
